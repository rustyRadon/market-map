  "query": "\n        SELECT \n            id, name, category, avg_price, min_price, max_price, \n            image_url, previous_price, last_updated \n        FROM products \n        WHERE name ILIKE $1 OR category ILIKE $1 \n        ORDER BY last_updated DESC\n        ",
